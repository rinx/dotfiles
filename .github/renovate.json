{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "extends": [
      "schedule:weekly"
    ]
  },
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Neovim plugins on Codeberg",
      "managerFilePatterns": ["/^nvim/fnl/rc/plugin-lock\\.fnl$/"],
      "matchStrings": [":codeberg/([a-zA-Z0-9._\\/-]+)\\s+\"([a-f0-9]{40})\""],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://codeberg.org/$1.git",
      "currentValueTemplate": "$2"
    },
    {
      "customType": "regex",
      "description": "Neovim plugins on GitHub",
      "managerFilePatterns": ["/^nvim/fnl/rc/plugin-lock\\.fnl$/"],
      "matchStrings": [":([^:/]+/[^:/]+)\\s+\"([a-f0-9]{40})\""],
      "datasourceTemplate": "github-digest",
      "packageNameTemplate": "$1",
      "currentValueTemplate": "$2"
    }
  ]
}
